# ── Anthropic ──────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Claude model override (optional) ──────────────────────────────────────────
# Valid values: claude-haiku-4-20250514 | claude-sonnet-4-20250514 | claude-opus-4-20250514
# Defaults to claude-sonnet-4-20250514 if not set.
# Can also be changed live from /admin/settings (persists in KV, no redeploy needed).
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Admin panel credentials ────────────────────────────────────────────────────
# Change these before deploying to production!
ADMIN_USER=admin
ADMIN_PASS=admin
ADMIN_SECRET=change_me_to_a_long_random_string

# ── Vercel KV (for dynamic admin settings + beta key gate) ────────────────────
# See SETUP.md for instructions on setting up Vercel KV.
# Without these, the app uses DEFAULT_CONFIG from lib/config.ts and works normally.
# These are automatically populated when you connect a KV database in the Vercel dashboard.
KV_URL=your_vercel_kv_url_here
KV_REST_API_URL=your_vercel_kv_rest_api_url_here
KV_REST_API_TOKEN=your_vercel_kv_rest_api_token_here
KV_REST_API_READ_ONLY_TOKEN=your_vercel_kv_rest_api_read_only_token_here
