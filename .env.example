# ── Anthropic ──────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Claude model selection ────────────────────────────────────────────────────
# RECOMMENDED: Use /admin/settings to change the model (persists in KV, no redeploy needed).
#
# This env var is a fallback only — it's never persisted and the KV config takes precedence.
# Valid values: claude-haiku-4-5-20251001 (default, cost-efficient)
#               claude-sonnet-4-20250514 (balanced)
#               claude-opus-4-20250514 (most capable)
# CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Session signing secret ─────────────────────────────────────────────────────
# Used to sign beta session tokens (HMAC-SHA256). Must be at least 32 random chars.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production — the app will throw on startup if missing or too short.
SESSION_SECRET=generate-a-random-32-char-string-with-the-command-above

# ── Admin panel credentials ────────────────────────────────────────────────────
# Change these before deploying to production!
ADMIN_USER=admin
ADMIN_PASS=admin
ADMIN_SECRET=change_me_to_a_long_random_string

# ── Vercel KV (for dynamic admin settings + beta key gate) ────────────────────
# See SETUP.md for instructions on setting up Vercel KV.
# Without these, the app uses DEFAULT_CONFIG from lib/config.ts and works normally.
# These are automatically populated when you connect a KV database in the Vercel dashboard.
KV_URL=your_vercel_kv_url_here
KV_REST_API_URL=your_vercel_kv_rest_api_url_here
KV_REST_API_TOKEN=your_vercel_kv_rest_api_token_here
KV_REST_API_READ_ONLY_TOKEN=your_vercel_kv_rest_api_read_only_token_here

# ── Email / SMTP Configuration ─────────────────────────────────────────────
# Optional: Email notifications when users submit equipment suggestions.
# If not configured, suggestions are still saved to KV but no emails are sent.
#
# SMTP_HOST: SMTP server hostname (e.g. smtp.gmail.com, smtp-relay.brevo.com)
# SMTP_PORT: SMTP port (default: 587 for TLS, 465 for SSL)
# SMTP_USER: SMTP username or email address
# SMTP_PASS: SMTP password or app-specific password
# ADMIN_EMAIL: Email address to receive suggestion notifications (default: info@printperfect.app)
#
# Common providers:
#   Gmail: Set SMTP_HOST=smtp.gmail.com, use an app-specific password
#   Brevo (Sendinblue): Set SMTP_HOST=smtp-relay.brevo.com
#   SendGrid: Set SMTP_HOST=smtp.sendgrid.net, SMTP_USER=apikey
#   Any other: Use your provider's SMTP credentials
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password_here
# ADMIN_EMAIL=info@printperfect.app
