# ── Anthropic ──────────────────────────────────────────────────────────────────
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Claude model override (optional) ──────────────────────────────────────────
# Valid values: claude-haiku-4-20250514 | claude-sonnet-4-20250514 | claude-opus-4-5
# Defaults to claude-sonnet-4-20250514 if not set.
# Can also be changed live from the /admin panel (persists until server restart).
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── Admin panel credentials ────────────────────────────────────────────────────
# Change these before deploying to production!
ADMIN_USER=admin
ADMIN_PASS=admin
ADMIN_SECRET=change_me_to_a_long_random_string
